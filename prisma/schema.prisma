generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId    BigInt   @id @default(autoincrement()) @map("user_id")
  mail      String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  firstname String   @db.VarChar(100)
  surname   String   @db.VarChar(100)
  level     Int      @db.SmallInt // 0 = enseignant, 1 = responsable, 2 = admin

  // Relations
  subjectAddingCaches SubjectAddingCache[]
  teacherAssignments   TeacherAssignments[]
  sessions Session[]

  @@map("user")
}

model Session {
  sessionId BigInt   @id @default(autoincrement()) @map("session_id")
  userId    BigInt   @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("session")
}

model Student {
  studentId BigInt @id @default(autoincrement()) @map("student_id")
  classId   Int?    @map("class_id") @db.SmallInt
  firstname String @db.VarChar(100)
  surname   String @db.VarChar(100)

  // Relations
  class              Class?                @relation(fields: [classId], references: [classId], onDelete: Cascade)
  studentAssignments StudentAssignments[]
  subjectAssignments SubjectAssignments[]
  grades             Grade[]

  @@map("student")
}

model Class {
  classId Int    @id @default(autoincrement()) @map("class_id") @db.SmallInt
  label   String @db.VarChar(100)

  // Relations
  students Student[]

  @@map("class")
}

model Subject {
  subjectId Int    @id @default(autoincrement()) @map("subject_id") @db.SmallInt
  label     String @db.VarChar(100)

  // Relations
  subjectAssignments  SubjectAssignments[]
  subjectAddingCaches SubjectAddingCache[]
  teacherAssignments   TeacherAssignments[]

  @@map("subject")
}

model StudentAssignments {
  studentId BigInt @map("student_id")
  groupId   BigInt @map("group_id")

  student Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  @@id([studentId, groupId])
  @@map("student_assignments")
}

model Group {
  groupId BigInt @id @default(autoincrement()) @map("group_id")
  label   String @db.VarChar(100)

  // Relations
  studentAssignments StudentAssignments[]

  @@map("group")
}

model SubjectAssignments {
  studentId BigInt @map("student_id")
  subjectId Int    @map("subject_id") @db.SmallInt

  student   Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  @@id([studentId, subjectId])
  @@map("subject_assignments")
}

model TeacherAssignments {
  subjectId Int    @map("subject_id") @db.SmallInt
  teacherId BigInt @map("teacher_id")

  subject Subject @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [userId], onDelete: Cascade)

  @@id([subjectId, teacherId])
  @@map("teacher_assignments")
}

model SubjectAddingCache {
  userId    BigInt @map("user_id")
  subjectId Int    @map("subject_id") @db.SmallInt
  students  String @db.Text // Zone de texte pour stocker le cache

  user    User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  @@id([userId, subjectId])
  @@map("subject_adding_cache")
}

model Assessment {
  assessmentId BigInt   @id @default(autoincrement()) @map("assessment_id")
  subjectId    Int      @map("subject_id") @db.SmallInt
  date         DateTime @db.Date
  maxGrade     Int      @map("max_grade") @db.SmallInt
  weight       Int      @db.SmallInt
  teacher      String   @db.VarChar(100)
  label        String   @db.VarChar(255)

  // Relations
  grades Grade[]

  @@map("assessment")
}

model Grade {
  assessmentId BigInt @map("assessment_id")
  studentId    BigInt @map("student_id")
  value        Int    @db.SmallInt // Note de l'étudiant
  feedback     String @db.Text

  assessment Assessment @relation(fields: [assessmentId], references: [assessmentId], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@id([assessmentId, studentId])
  @@map("grade")
}