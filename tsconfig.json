/**
 * tsconfig.json
 * 
 * Configuration TypeScript
 * 
 * Rôle:
 * - Configure le compilateur TypeScript pour le projet
 * - Définit les options de compilation et résolution des modules
 * - Configure les chemins d'imports alias (@/*)
 * - Integre la configuration Next.js via le plugin next
 * 
 * Points clés:
 * - strict: true - Mode strict pour plus de sécurité des types
 * - paths: @/* pour les imports depuis la racine
 * - jsx: react-jsx - Utilise React 19 JSX runtime
 * - moduleResolution: bundler - Résolution moderne des modules
 */

{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules"]
}
